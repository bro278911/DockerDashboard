<Window x:Class="DockerDashboard.Views.Wsl2GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="WSL2 Docker 安裝指南" Height="760" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <Style x:Key="TerminalChipPs" TargetType="Border">
            <Setter Property="Background" Value="#1565C0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="TerminalChipWsl" TargetType="Border">
            <Setter Property="Background" Value="#1B5E20" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="WSL2 Docker Engine 安裝步驟"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── 步驟 1 ── -->
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,6">步驟 1：安裝 WSL2</TextBlock>
                <Border Style="{StaticResource TerminalChipPs}">
                    <TextBlock Text="📋  PowerShell（系統管理員）" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                </Border>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">
                    以系統管理員身份開啟 PowerShell，執行下列指令，完成後重新啟動 Windows：
                </TextBlock>
                <Border Background="#263238" CornerRadius="4" Margin="0,0,0,4">
                    <StackPanel>
                        <Button HorizontalAlignment="Right" Content="複製"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                Click="CopyStep1_Click" />
                        <TextBox x:Name="Step1Box"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap" Padding="12,4,12,12"
                                 Text="wsl --install" />
                    </StackPanel>
                </Border>
                <TextBlock Foreground="Gray" FontSize="11" Margin="0,0,0,8">
                    預設安裝 Ubuntu；若需指定版本：wsl --install -d Ubuntu-24.04
                </TextBlock>

                <!-- 重新啟動後說明 -->
                <Border Background="#263238" CornerRadius="4" Padding="12,10" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Foreground="#FFD54F" FontWeight="Bold" FontSize="12" Margin="0,0,0,6">
                            重新啟動 Windows 後，如何開啟 Ubuntu 終端？
                        </TextBlock>
                        <TextBlock Foreground="#ECEFF1" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4">
                            方法 A：開始功能表 → 搜尋「Ubuntu」→ 點擊開啟
                        </TextBlock>
                        <TextBlock Foreground="#ECEFF1" FontSize="12" Margin="0,0,0,4">方法 B：在任意終端輸入：</TextBlock>
                        <TextBox IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                 Text="wsl" Padding="0,0,0,2" />
                        <TextBlock Foreground="#B0BEC5" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0">
                            ⚠️  步驟 2 以後的所有指令，請在 Ubuntu 終端中執行，不是 PowerShell！
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ── 步驟 2 ── -->
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,6">步驟 2：安裝 Docker Engine</TextBlock>
                <Border Style="{StaticResource TerminalChipWsl}">
                    <TextBlock Text="🐧  WSL Ubuntu 終端（不是 PowerShell）" Foreground="#A5D6A7" FontSize="11" FontWeight="SemiBold" />
                </Border>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">
                    在 Ubuntu 終端中，依序執行以下指令：
                </TextBlock>
                <Border Background="#263238" CornerRadius="4" Margin="0,0,0,4">
                    <StackPanel>
                        <Button HorizontalAlignment="Right" Content="複製"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                Click="CopyStep2_Click" />
                        <TextBox x:Name="Step2Box"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap" Padding="12,4,12,12"
                                 Text="curl -fsSL https://get.docker.com | sh&#x0a;sudo usermod -aG docker $USER" />
                    </StackPanel>
                </Border>
                <TextBlock Foreground="Gray" FontSize="11" Margin="0,0,0,24">
                    完成後關閉 Ubuntu 視窗並重新開啟（讓 docker 群組設定生效）
                </TextBlock>

                <!-- ── 步驟 3（Ubuntu 22.04 限定） ── -->
                <Border Background="#4A148C" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                    <TextBlock Foreground="#E1BEE7" TextWrapping="Wrap" FontSize="12">
                        ℹ️  以下步驟僅 Ubuntu 22.04 需要，Ubuntu 24.04 請直接跳到步驟 4
                    </TextBlock>
                </Border>
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,6">步驟 3：修正 iptables（Ubuntu 22.04 限定）</TextBlock>
                <Border Style="{StaticResource TerminalChipWsl}">
                    <TextBlock Text="🐧  WSL Ubuntu 終端" Foreground="#A5D6A7" FontSize="11" FontWeight="SemiBold" />
                </Border>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">
                    Ubuntu 22.04 預設使用 nftables，Docker 無法啟動，需切換為 legacy 模式：
                </TextBlock>
                <Border Background="#263238" CornerRadius="4" Margin="0,0,0,24">
                    <StackPanel>
                        <Button HorizontalAlignment="Right" Content="複製"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                Click="CopyStep3_Click" />
                        <TextBox x:Name="Step3Box"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap" Padding="12,4,12,12"
                                 Text="sudo update-alternatives --set iptables /usr/sbin/iptables-legacy" />
                    </StackPanel>
                </Border>

                <!-- ── 步驟 4 ── -->
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,6">步驟 4：設定 Docker 自動啟動（可選）</TextBlock>

                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">① 在 Ubuntu 終端中寫入設定檔：</TextBlock>
                <Border Style="{StaticResource TerminalChipWsl}">
                    <TextBlock Text="🐧  WSL Ubuntu 終端" Foreground="#A5D6A7" FontSize="11" FontWeight="SemiBold" />
                </Border>
                <Border Background="#263238" CornerRadius="4" Margin="0,0,0,4">
                    <StackPanel>
                        <Button HorizontalAlignment="Right" Content="複製"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                Click="CopyStep4a_Click" />
                        <TextBox x:Name="Step4aBox"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap" Padding="12,4,12,12"
                                 Text="printf '[boot]\ncommand = service docker start\n' | sudo tee /etc/wsl.conf" />
                    </StackPanel>
                </Border>
                <TextBlock Foreground="Gray" FontSize="11" Margin="0,0,0,10">
                    若 /etc/wsl.conf 已存在，請手動加入 [boot] 段落
                </TextBlock>

                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">② 關閉 Ubuntu 視窗，然後在 PowerShell 執行：</TextBlock>
                <Border Style="{StaticResource TerminalChipPs}">
                    <TextBlock Text="📋  PowerShell" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                </Border>
                <Border Background="#263238" CornerRadius="4" Margin="0,0,0,4">
                    <StackPanel>
                        <Button HorizontalAlignment="Right" Content="複製"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                Click="CopyStep4b_Click" />
                        <TextBox x:Name="Step4bBox"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap" Padding="12,4,12,12"
                                 Text="wsl --shutdown" />
                    </StackPanel>
                </Border>
                <TextBlock Foreground="Gray" FontSize="11" Margin="0,0,0,24">
                    之後重新開啟 Ubuntu，Docker 將自動啟動
                </TextBlock>

                <!-- ── 步驟 5（可選）── -->
                <Border Background="#1A237E" CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
                    <TextBlock Foreground="#C5CAE9" TextWrapping="Wrap" FontSize="12">
                        💡  以下步驟為可選，僅當你需要將 WSL2 安裝至 C 槽以外的磁碟時才需要執行
                    </TextBlock>
                </Border>
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,6">步驟 5（可選）：搬移 WSL2 至指定磁碟（例如 D 槽）</TextBlock>
                <Border Style="{StaticResource TerminalChipPs}">
                    <TextBlock Text="📋  PowerShell" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                </Border>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">
                    先匯出現有 distro，再重新匯入到目標位置（約需數分鐘）：
                </TextBlock>
                <Border Background="#263238" CornerRadius="4" Margin="0,0,0,4">
                    <StackPanel>
                        <Button HorizontalAlignment="Right" Content="複製"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                Click="CopyStep5a_Click" />
                        <TextBox x:Name="Step5aBox"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap" Padding="12,4,12,12"
                                 Text="wsl --export Ubuntu D:\WSL\Ubuntu.tar&#x0a;wsl --unregister Ubuntu&#x0a;wsl --import Ubuntu D:\WSL\Ubuntu D:\WSL\Ubuntu.tar --version 2" />
                    </StackPanel>
                </Border>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">
                    匯入後預設使用者會變成 root，執行以下指令修正（將 your_username 替換為你的帳號）：
                </TextBlock>
                <Border Background="#263238" CornerRadius="4" Margin="0,0,0,4">
                    <StackPanel>
                        <Button HorizontalAlignment="Right" Content="複製"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                Click="CopyStep5b_Click" />
                        <TextBox x:Name="Step5bBox"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap" Padding="12,4,12,12"
                                 Text="Ubuntu config --default-user your_username" />
                    </StackPanel>
                </Border>
                <TextBlock Foreground="Gray" FontSize="11" Margin="0,0,0,24">
                    D 槽需為 NTFS 格式；WSL kernel 本體仍在 C 槽，搬移的是 distro 的虛擬磁碟 (.vhdx)
                </TextBlock>

                <!-- ── 步驟 6 ── -->
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,6">步驟 6：驗證安裝</TextBlock>
                <Border Style="{StaticResource TerminalChipWsl}">
                    <TextBlock Text="🐧  WSL Ubuntu 終端" Foreground="#A5D6A7" FontSize="11" FontWeight="SemiBold" />
                </Border>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" FontSize="12">
                    確認 Docker 已正常安裝：
                </TextBlock>
                <Border Background="#263238" CornerRadius="4" Margin="0,0,0,16">
                    <StackPanel>
                        <Button HorizontalAlignment="Right" Content="複製"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                Click="CopyStep6_Click" />
                        <TextBox x:Name="Step6Box"
                                 IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                 Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                 TextWrapping="Wrap" Padding="12,4,12,12"
                                 Text="docker version&#x0a;docker compose version" />
                    </StackPanel>
                </Border>

                <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="12" Margin="0,0,0,24">
                    完成後，回到本工具「設定」→ 選擇「WSL2 原生 Docker」→ 輸入發行版名稱（預設 Ubuntu）→ 點擊「測試連線」。
                </TextBlock>

                <!-- ── 常見問題 ── -->
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,10">常見問題</TextBlock>

                <!-- Q1: 0x80070569 -->
                <Border Background="#37474F" CornerRadius="4" Padding="12,10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Foreground="#EF9A9A" FontWeight="Bold" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4">
                            ❌  錯誤：Wsl/Service/CreateInstance/CreateVm/HCS/0x80070569
                        </TextBlock>
                        <TextBlock Foreground="#ECEFF1" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">
                            原因：目前帳號缺少 Hyper-V VM 建立權限。用系統管理員 PowerShell 執行：
                        </TextBlock>
                        <Border Style="{StaticResource TerminalChipPs}">
                            <TextBlock Text="📋  PowerShell（系統管理員）" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#263238" CornerRadius="4" Margin="0,4,0,8">
                            <StackPanel>
                                <Button HorizontalAlignment="Right" Content="複製"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                        Click="CopyFix1_Click" />
                                <TextBox x:Name="Fix1Box"
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                         Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                         TextWrapping="Wrap" Padding="12,4,12,12"
                                         Text="net localgroup &quot;Hyper-V Administrators&quot; $env:USERNAME /add" />
                            </StackPanel>
                        </Border>
                        <TextBlock Foreground="#B0BEC5" FontSize="11" TextWrapping="Wrap">
                            執行後登出再登入 Windows（非重開機），即可解決。若是公司網域機器，需請 IT 人員協助加入群組。
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Q2: sudo 無法使用 -->
                <Border Background="#37474F" CornerRadius="4" Padding="12,10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Foreground="#EF9A9A" FontWeight="Bold" FontSize="12" Margin="0,0,0,4">
                            ❌  錯誤：此電腦上已停用 Sudo / 'sh' 無法辨識
                        </TextBlock>
                        <TextBlock Foreground="#ECEFF1" FontSize="12" TextWrapping="Wrap">
                            原因：步驟 2 的指令被貼到 Windows PowerShell 執行。這些指令必須在 WSL Ubuntu 終端機中執行。
                            請開啟「開始功能表」→ 搜尋「Ubuntu」→ 開啟後再執行。
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Q3: 建置 OOM -->
                <Border Background="#37474F" CornerRadius="4" Padding="12,10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Foreground="#EF9A9A" FontWeight="Bold" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4">
                            ❌  建置（重建 image）時卡住、失敗或 WSL2 記憶體不足
                        </TextBlock>
                        <TextBlock Foreground="#ECEFF1" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8">
                            WSL2 預設最多使用主機 50% 記憶體，建置大型 image 時容易 OOM。
                            在 Windows 建立 .wslconfig 設定檔限制或擴充資源：
                        </TextBlock>
                        <Border Style="{StaticResource TerminalChipPs}">
                            <TextBlock Text="📋  PowerShell" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#263238" CornerRadius="4" Margin="0,4,0,8">
                            <StackPanel>
                                <Button HorizontalAlignment="Right" Content="複製"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Foreground="#78909C" FontSize="11" Height="26" Padding="8,0"
                                        Click="CopyFix2_Click" />
                                <TextBox x:Name="Fix2Box"
                                         IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                         Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                         TextWrapping="Wrap" Padding="12,4,12,12"
                                         Text="# 建立或編輯 %USERPROFILE%\.wslconfig&#x0a;notepad &quot;$env:USERPROFILE\.wslconfig&quot;" />
                            </StackPanel>
                        </Border>
                        <TextBlock Foreground="#ECEFF1" FontSize="12" Margin="0,0,0,4">在檔案中加入：</TextBlock>
                        <Border Background="#263238" CornerRadius="4" Margin="0,0,0,8">
                            <TextBox IsReadOnly="True" Background="Transparent" BorderThickness="0"
                                     Foreground="#A5D6A7" FontFamily="Consolas" FontSize="13"
                                     TextWrapping="Wrap" Padding="12,8"
                                     Text="[wsl2]&#x0a;memory=8GB&#x0a;processors=4" />
                        </Border>
                        <TextBlock Foreground="#B0BEC5" FontSize="11" TextWrapping="Wrap">
                            設定後執行 wsl --shutdown 重啟 WSL2 生效。memory 建議設為主機實體記憶體的 50~75%。
                            本工具在 WSL2 模式下已自動限制建置並行數（BUILDKIT_MAX_PARALLELISM=1）以降低記憶體需求。
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="關閉" HorizontalAlignment="Right" Margin="0,16,0,0"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Click="Close_Click" />
    </Grid>
</Window>
