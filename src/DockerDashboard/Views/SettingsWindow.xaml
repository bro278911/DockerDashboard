<Window x:Class="DockerDashboard.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="設定" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,24,24,8">

                <!-- 輪詢間隔 -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="狀態輪詢間隔（秒）" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding ElementName=PollSlider, Path=Value, StringFormat={}{0:0}}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="30" />
                        <Slider x:Name="PollSlider" Minimum="2" Maximum="30"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Style="{StaticResource MaterialDesignDiscreteSlider}" />
                    </DockPanel>
                </StackPanel>

                <!-- Compose V2 -->
                <StackPanel Margin="0,0,0,16">
                    <DockPanel>
                        <TextBlock Text="使用 Docker Compose V2 (docker compose)"
                                   VerticalAlignment="Center" DockPanel.Dock="Left" />
                        <ToggleButton x:Name="ComposeV2Toggle" DockPanel.Dock="Right"
                                      HorizontalAlignment="Right"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    </DockPanel>
                </StackPanel>

                <!-- Docker 執行模式 -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Docker 執行模式" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ModeDockerDesktop" Content="Docker Desktop"
                                     GroupName="DockerMode" Margin="0,0,24,0"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Checked="DockerMode_Changed" />
                        <RadioButton x:Name="ModeWsl2" Content="WSL2 原生 Docker"
                                     GroupName="DockerMode"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Checked="DockerMode_Changed" />
                    </StackPanel>
                </StackPanel>

                <!-- WSL2 設定（僅 WSL2 模式顯示） -->
                <StackPanel x:Name="Wsl2Panel" Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock Text="WSL 發行版名稱" Margin="0,0,0,4" />
                    <DockPanel>
                        <Button x:Name="TestConnectionBtn" Content="測試連線" DockPanel.Dock="Right"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="8,0,0,0" Click="TestConnection_Click" />
                        <TextBox x:Name="WslDistroBox"
                                 materialDesign:HintAssist.Hint="例如: Ubuntu"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </DockPanel>
                    <TextBlock x:Name="TestResultText" Margin="0,8,0,0" FontSize="12"
                               TextWrapping="Wrap" />
                    <Button Content="📖 WSL2 Docker 安裝指南" Margin="0,8,0,0"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalAlignment="Left" Click="OpenWsl2Guide_Click" />
                    <Border Margin="0,8,0,0" Padding="10,8" CornerRadius="4"
                            Background="{DynamicResource MaterialDesign.Brush.Primary.Light}">
                        <StackPanel>
                            <TextBlock Text="💡 建議設定 %USERPROFILE%\.wslconfig 以提升建置效能："
                                       FontSize="12" TextWrapping="Wrap" Opacity="0.9" />
                            <TextBlock FontSize="11" FontFamily="Consolas" Margin="0,4,0,0" Opacity="0.8"
                                       Text="[wsl2]&#x0a;processors=8&#x0a;memory=12GB" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Auto Watch & Rebuild -->
                <StackPanel Margin="0,0,0,16">
                    <DockPanel>
                        <TextBlock Text="Auto Watch &amp; Rebuild（檔案變動自動重建）"
                                   VerticalAlignment="Center" DockPanel.Dock="Left" />
                        <ToggleButton x:Name="AutoWatchToggle" DockPanel.Dock="Right"
                                      HorizontalAlignment="Right"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                    </DockPanel>
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock DockPanel.Dock="Left" Text="Debounce 延遲："
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding ElementName=WatchDebounceSlider, Path=Value, StringFormat={}{0:0} 秒}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="44" />
                        <Slider x:Name="WatchDebounceSlider" Minimum="1" Maximum="10"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Style="{StaticResource MaterialDesignDiscreteSlider}" />
                    </DockPanel>
                </StackPanel>

                <!-- BuildKit 建置平行度 -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="BuildKit 建置平行度" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
                    <TextBlock FontSize="11" Opacity="0.7" Margin="0,2,0,0" TextWrapping="Wrap"
                               Text="控制 Docker 建置時的平行層數。0=自動（BuildKit 預設，建議），1=保守（舊行為），2–8=手動指定。WSL2 建議從 2 開始嘗試。" />
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding ElementName=BuildKitSlider, Path=Value, StringFormat={}{0:0}}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" Width="30" />
                        <Slider x:Name="BuildKitSlider" Minimum="0" Maximum="8"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Style="{StaticResource MaterialDesignDiscreteSlider}" />
                    </DockPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- 按鈕（釘底） -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16">
            <Button Content="取消" Style="{StaticResource MaterialDesignFlatButton}"
                    IsCancel="True" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="儲存" Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
