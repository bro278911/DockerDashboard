<Window x:Class="DockerDashboard.Views.DockerRepairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Docker 修復工具" Height="560" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 標題 + 說明 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <materialDesign:PackIcon Kind="Wrench" Width="22" Height="22"
                                         Foreground="#FF9800" VerticalAlignment="Center" />
                <TextBlock Text="Docker 修復工具" Margin="8,0,0,0"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <Border Background="#FFF3E0" BorderBrush="#FF9800" BorderThickness="1"
                    CornerRadius="4" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Alert" Foreground="#E65100"
                                             VerticalAlignment="Top" Margin="0,1,8,0" />
                    <TextBlock TextWrapping="Wrap" Foreground="#E65100" FontSize="12">
                        清除操作無法還原。Image 刪除後需重新 build 或 pull。<LineBreak />
                        Volume 清除可能導致資料遺失，請先確認容器均已停止。
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 修復選項 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="選擇修復項目" Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                       Margin="0,0,0,8" />

            <!-- 選項 1 -->
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
                    CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
                <DockPanel>
                    <CheckBox x:Name="PruneDanglingCheck" DockPanel.Dock="Left"
                              VerticalAlignment="Center" IsChecked="True"
                              Style="{StaticResource MaterialDesignCheckBox}" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="清除懸空 Image（Dangling）" FontWeight="Medium" />
                        <TextBlock Text="docker image prune -f　　低風險，只移除未標記的殘留層"
                                   FontSize="11" Foreground="Gray" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 選項 2 -->
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
                    CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
                <DockPanel>
                    <CheckBox x:Name="PruneAllImagesCheck" DockPanel.Dock="Left"
                              VerticalAlignment="Center"
                              Style="{StaticResource MaterialDesignCheckBox}" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="清除所有未使用 Image" FontWeight="Medium" />
                        <TextBlock Text="docker image prune -af　　中風險，移除所有容器未在使用的 image"
                                   FontSize="11" Foreground="Gray" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 選項 3 -->
            <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1"
                    CornerRadius="4" Padding="12,10" Margin="0,0,0,6">
                <DockPanel>
                    <CheckBox x:Name="PruneVolumesCheck" DockPanel.Dock="Left"
                              VerticalAlignment="Center"
                              Style="{StaticResource MaterialDesignCheckBox}" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="清除未使用 Volume" FontWeight="Medium" />
                        <TextBlock Text="docker volume prune -f　　中風險，移除未掛載的 volume（注意資料遺失）"
                                   FontSize="11" Foreground="#E65100" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 選項 4 -->
            <Border BorderBrush="#F44336" BorderThickness="1"
                    CornerRadius="4" Padding="12,10" Margin="0,0,0,0">
                <DockPanel>
                    <CheckBox x:Name="SystemPruneCheck" DockPanel.Dock="Left"
                              VerticalAlignment="Center"
                              Style="{StaticResource MaterialDesignCheckBox}" />
                    <StackPanel Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="完整系統清除" FontWeight="Medium" />
                            <Border Background="#F44336" CornerRadius="3" Padding="5,1" Margin="8,0,0,0">
                                <TextBlock Text="高風險" FontSize="10" Foreground="White" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="docker system prune -af --volumes　　清除所有 image、volume、network"
                                   FontSize="11" Foreground="#C62828" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </StackPanel>

        <!-- 輸出日誌 -->
        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="8,6">
                    <TextBlock Text="執行輸出" Foreground="#9E9E9E" FontSize="12"
                               DockPanel.Dock="Left" VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusLabel" Foreground="#9E9E9E" FontSize="11"
                               DockPanel.Dock="Right" HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </DockPanel>
                <ScrollViewer Grid.Row="1" x:Name="LogScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Margin="0,0,0,6">
                    <TextBlock x:Name="LogText"
                               FontFamily="Consolas, Courier New"
                               FontSize="11" Foreground="#E0E0E0"
                               TextWrapping="NoWrap"
                               Padding="10,4" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 按鈕 -->
        <DockPanel Grid.Row="3">
            <ProgressBar x:Name="RepairProgress"
                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Width="22" Height="22"
                         DockPanel.Dock="Left" Visibility="Collapsed"
                         VerticalAlignment="Center" Margin="0,0,12,0" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="RepairBtn" Content="開始修復"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#FF9800" Foreground="White"
                        Margin="0,0,8,0" Click="Repair_Click" />
                <Button x:Name="CloseBtn" Content="關閉"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Click="Close_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
