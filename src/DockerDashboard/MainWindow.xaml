<Window x:Class="DockerDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:DockerDashboard.Converters"
        xmlns:models="clr-namespace:DockerDashboard.Models"
        mc:Ignorable="d"
        Title="Docker Dashboard" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
    <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
    <converters:StatusToIconConverter x:Key="StatusToIconConverter" />
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <converters:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 工具列 -->
        <materialDesign:Card Grid.Row="0" Margin="8,8,8,4" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding ImportFolderCommand}"
                        ToolTip="匯入專案資料夾">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderPlus" VerticalAlignment="Center" />
                        <TextBlock Text="匯入資料夾" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="8,0" />

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding AllUpCommand}"
                        IsEnabled="{Binding CanAllUp}"
                        Foreground="#4CAF50"
                        ToolTip="啟動所有服務（不重建 image，速度快）">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlayCircle" VerticalAlignment="Center" />
                        <TextBlock Text="全部啟動" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding AllUpIncrementalBuildCommand}"
                        IsEnabled="{Binding CanRebuild}"
                        Foreground="#2196F3"
                        ToolTip="增量重建所有 image（使用 cache，只重建有變動的層，速度快）">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" />
                        <TextBlock Text="增量重建" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding AllUpBuildCommand}"
                        IsEnabled="{Binding CanAllUp}"
                        Foreground="#FF9800"
                        ToolTip="強制重建所有 image（--no-cache，砍掉舊 image 從頭建，耗時較長）">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Hammer" VerticalAlignment="Center" />
                        <TextBlock Text="完整重建" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding AllDownCommand}"
                        IsEnabled="{Binding CanAllDown}"
                        Foreground="#F44336"
                        ToolTip="停止所有服務">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="StopCircle" VerticalAlignment="Center" />
                        <TextBlock Text="全部停止" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="8,0" />

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding RescanProjectsCommand}"
                        ToolTip="重新掃描所有資料夾">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" />
                        <TextBlock Text="重新掃描" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding PullAllImagesCommand}"
                        ToolTip="拉取所有映像更新"
                        Foreground="#9C27B0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Download" VerticalAlignment="Center" />
                        <TextBlock Text="拉取映像" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="8,0" />

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding OpenRepairWindowCommand}"
                        Foreground="#FF9800"
                        ToolTip="修復 Docker（清除損毀 image/volume）">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Wrench" VerticalAlignment="Center" />
                        <TextBlock Text="修復" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding OpenSettingsCommand}"
                        ToolTip="開啟設定">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cog" VerticalAlignment="Center" />
                        <TextBlock Text="設定" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="8,0" />

                <!-- 發現新版本後顯示（HasUpdate = true） -->
                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding InstallUpdateCommand}"
                        IsEnabled="{Binding CanInstallUpdate}"
                        Foreground="#4CAF50"
                        ToolTip="點擊下載並安裝更新，完成後自動重啟應用程式"
                        Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloudDownload" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding UpdateStatusText}" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- 操作中指示器 + 取消按鈕 -->
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Visibility="{Binding IsOperating, Converter={StaticResource BoolToVisibilityConverter}}"
                             Width="20" Height="20" Margin="12,0,0,0" />

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding CancelOperationCommand}"
                        IsEnabled="{Binding CanCancelOperation}"
                        Visibility="{Binding IsOperating, Converter={StaticResource BoolToVisibilityConverter}}"
                        Foreground="#F44336"
                        Margin="4,0,0,0"
                        ToolTip="取消當前操作（中止並 kill docker 子進程）">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cancel" VerticalAlignment="Center" />
                        <TextBlock Text="取消" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <!-- 主要內容區 -->
        <Grid Grid.Row="1" Margin="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左側：專案樹 -->
            <materialDesign:Card Grid.Column="0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="專案與服務" 
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="12,8" />

                    <TreeView Grid.Row="1" 
                              ItemsSource="{Binding Projects}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              SelectedItemChanged="TreeView_SelectedItemChanged">
                        <TreeView.Resources>
                            <!-- 專案層級 -->
                            <HierarchicalDataTemplate DataType="{x:Type models:DockerProject}"
                                                      ItemsSource="{Binding ComposeFiles}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <materialDesign:PackIcon Kind="Folder" Foreground="#FFC107" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" Margin="6,0,0,0" VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                    <!-- Git 分支 chip -->
                                    <Border Background="#E3F2FD" CornerRadius="8" Padding="6,2" Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsGitRepo, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="SourceBranch" Width="12" Height="12" 
                                                                     Foreground="#1565C0" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding CurrentBranch}" Margin="4,0,0,0"
                                                       FontSize="11" Foreground="#1565C0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <!-- Dirty 指示 -->
                                    <Ellipse Width="8" Height="8" Fill="#FF9800" Margin="6,0,0,0"
                                             VerticalAlignment="Center"
                                             ToolTip="有未提交的變更"
                                             Visibility="{Binding IsDirty, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="切換分支"
                                                      Command="{Binding Data.SwitchBranchCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}"
                                                      IsEnabled="{Binding IsGitRepo}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="SourceBranch" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="重新整理 Git 狀態"
                                                      Command="{Binding Data.RefreshGitStatusCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}"
                                                      IsEnabled="{Binding IsGitRepo}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Refresh" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="移除專案"
                                                      Command="{Binding Data.RemoveProjectCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Delete" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- Compose 檔案層級 -->
                            <HierarchicalDataTemplate DataType="{x:Type models:ComposeFile}"
                                                      ItemsSource="{Binding Services}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <materialDesign:PackIcon Kind="Docker" Foreground="#2196F3" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding FileName}" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="啟動全部服務" 
                                                      Command="{Binding Data.ComposeUpCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Play" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="停止全部服務"
                                                      Command="{Binding Data.ComposeDownCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Stop" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="拉取映像更新"
                                                      Command="{Binding Data.ComposePullCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Download" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- 服務層級 -->
                            <DataTemplate DataType="{x:Type models:DockerService}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                               FontSize="12" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Image}" Margin="8,0,0,0"
                                               Foreground="Gray" FontSize="11" VerticalAlignment="Center" />
                                    <!-- Auto Watch 開關 -->
                                    <Button Width="20" Height="20" Padding="0" Margin="6,0,0,0"
                                            Command="{Binding Data.ToggleWatchServiceCommand, Source={StaticResource Proxy}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Auto Watch：啟用後，原始碼變動會自動重建並重啟此服務（需在設定開啟全域開關）">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                <Setter Property="Foreground" Value="Gray" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWatching}" Value="True">
                                                        <Setter Property="Foreground" Value="#4CAF50" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <materialDesign:PackIcon Kind="Eye" Width="13" Height="13" />
                                    </Button>
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="啟動"
                                                      Command="{Binding Data.StartServiceCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Play" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="停止"
                                                      Command="{Binding Data.StopServiceCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Stop" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="重啟（快速）"
                                                      Command="{Binding Data.RestartServiceCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}"
                                                      ToolTip="只重啟 process，不重建 image">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Restart" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="重建重啟"
                                                      Command="{Binding Data.RebuildRestartServiceCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}"
                                                      ToolTip="重新 build image 後重啟（改動程式碼後使用）">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Hammer" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Auto Watch 開關"
                                                      Command="{Binding Data.ToggleWatchServiceCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}"
                                                      ToolTip="檔案變動自動重建">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Eye" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="查看日誌"
                                                      Command="{Binding Data.ViewLogsCommand, Source={StaticResource Proxy}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <materialDesign:PackIcon Kind="Text" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                </StackPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </materialDesign:Card>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="Transparent" />

            <!-- 右側：詳細 + 日誌 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 容器詳細資訊 -->
                <materialDesign:Card Grid.Row="0" Margin="0,0,0,4" Padding="12"
                                     Visibility="{Binding SelectedService, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedService.Name}"
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
                                <TextBlock Text="{Binding SelectedService.Status, Converter={StaticResource StatusToIconConverter}}"
                                           Foreground="{Binding SelectedService.Status, Converter={StaticResource StatusToColorConverter}}"
                                           FontSize="16" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Image:" Foreground="Gray" />
                                <TextBlock Text="{Binding SelectedService.Image}" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="Ports:" Foreground="Gray" />
                                <TextBlock Margin="6,0,0,0" Foreground="#64B5F6">
                                    <TextBlock.Inlines>
                                        <Run Text="{Binding SelectedService.Ports, Mode=OneWay}" />
                                    </TextBlock.Inlines>
                                </TextBlock>
                                <Button Style="{StaticResource MaterialDesignFlatButton}"
                                        Content="🔗 開啟" FontSize="11" Height="22" Padding="4,0"
                                        Margin="8,0,0,0"
                                        Click="OpenPort_Click"
                                        Visibility="{Binding SelectedService.IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding StartServiceCommand}"
                                    CommandParameter="{Binding SelectedService}"
                                    IsEnabled="{Binding SelectedService.IsStopped}"
                                    ToolTip="啟動" Foreground="#4CAF50">
                                <materialDesign:PackIcon Kind="Play" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding StopServiceCommand}"
                                    CommandParameter="{Binding SelectedService}"
                                    IsEnabled="{Binding SelectedService.IsRunning}"
                                    ToolTip="停止" Foreground="#F44336">
                                <materialDesign:PackIcon Kind="Stop" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding RestartServiceCommand}"
                                    CommandParameter="{Binding SelectedService}"
                                    IsEnabled="{Binding SelectedService.IsRunning}"
                                    ToolTip="重啟（快速，不重建 image）" Foreground="#FF9800">
                                <materialDesign:PackIcon Kind="Restart" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Command="{Binding RebuildRestartServiceCommand}"
                                    CommandParameter="{Binding SelectedService}"
                                    IsEnabled="{Binding SelectedService.IsRunning}"
                                    ToolTip="重建重啟（重新 build image，改動程式碼後使用）" Foreground="#9C27B0">
                                <materialDesign:PackIcon Kind="Hammer" />
                            </Button>
                            <!-- Auto Watch 開關 -->
                            <Button Command="{Binding ToggleWatchServiceCommand}"
                                    CommandParameter="{Binding SelectedService}"
                                    ToolTip="Auto Watch：啟用後，原始碼變動自動重建並重啟（需在設定開啟全域開關）">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                        <Setter Property="Foreground" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedService.IsWatching}" Value="True">
                                                <Setter Property="Foreground" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <materialDesign:PackIcon Kind="Eye" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- 日誌面板 -->
                <materialDesign:Card Grid.Row="1" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="8,6">
                            <TextBlock Text="即時日誌" DockPanel.Dock="Left"
                                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                       VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBox Width="160" Margin="0,0,8,0"
                                         materialDesign:HintAssist.Hint="搜尋日誌..."
                                         materialDesign:TextFieldAssist.HasClearButton="True"
                                         Text="{Binding LogFilter, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         VerticalAlignment="Center" FontSize="12"
                                         Height="28" Padding="4,2" />
                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        Command="{Binding StopLogsCommand}" ToolTip="停止串流"
                                        Width="28" Height="28">
                                    <materialDesign:PackIcon Kind="Stop" Width="16" Height="16" />
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        Command="{Binding ExportLogsCommand}" ToolTip="匯出日誌"
                                        Width="28" Height="28">
                                    <materialDesign:PackIcon Kind="Download" Width="16" Height="16" />
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        Command="{Binding ClearLogsCommand}" ToolTip="清除日誌"
                                        Width="28" Height="28">
                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" />
                                </Button>
                            </StackPanel>
                        </DockPanel>

                        <ListBox Grid.Row="1" 
                                 ItemsSource="{Binding LogView}"
                                 FontFamily="Consolas, Courier New"
                                 FontSize="12"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="NoWrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- 狀態列 -->
        <materialDesign:Card Grid.Row="2" Margin="8,4,8,8" Padding="8,4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock Text="🟢" FontSize="10" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding RunningCount, StringFormat='Running: {0}'}" 
                               Margin="4,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="🔴" FontSize="10" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StoppedCount, StringFormat='Stopped: {0}'}" 
                               Margin="4,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="📊" FontSize="10" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalCount, StringFormat='Total: {0}'}" 
                               Margin="4,0,16,0" VerticalAlignment="Center" />
                    <Border Background="#1E88E5" CornerRadius="3" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DockerModeLabel}" FontSize="11"
                                   Foreground="White" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="Gray" />
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</Window>
